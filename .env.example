# Mission Control Tool - Environment Variables

# Backend Server
PORT=4432
LOG_LEVEL=info

# Monitoring Thresholds (optional)
CPU_THRESHOLD=80
MEMORY_THRESHOLD=80
DISK_THRESHOLD=90

# Backup Settings
BACKUP_DIR=/tmp/mission-control-backups
BACKUP_SCHEDULE=0 0 * * *

# Update Settings
UPDATE_SCHEDULE=0 3 * * *

# OpenClaw Integration
OPENCLAW_API_TIMEOUT=5000

# Notifications
# Enable/disable notifications (default: true)
NOTIFICATIONS_ENABLED=true
# Discord user ID for DM notifications (get from Discord: Settings > Advanced > Enable Developer Mode, then right-click your user > Copy User ID)
DISCORD_USER_ID=
# Enable/disable specific notification types
NOTIFY_ON_COMPLETE=true
NOTIFY_ON_FAILED=true

# Data Persistence
# Directory for persistent data storage (tasks, etc.)
# In containers, use a volume mount like /app/data
DATA_DIR=/app/data

# Frontend API URL (for external access)
# Set this to the externally accessible backend URL when exposing Mission Control
# The frontend will use this URL for API calls
# Example: API_URL=https://api.yourdomain.com
API_URL=http://localhost:4432

# Basic Authentication (optional)
# Set AUTH_ENABLED=true to enable basic auth
# When enabled, all endpoints except /health require authentication
AUTH_ENABLED=false
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme