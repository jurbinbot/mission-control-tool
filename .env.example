# Mission Control Tool - Environment Variables

# Backend Server
PORT=3001
LOG_LEVEL=info

# Monitoring Thresholds (optional)
CPU_THRESHOLD=80
MEMORY_THRESHOLD=80
DISK_THRESHOLD=90

# Backup Settings
BACKUP_DIR=/tmp/mission-control-backups
BACKUP_SCHEDULE=0 0 * * *

# Update Settings
UPDATE_SCHEDULE=0 3 * * *

# OpenClaw Integration
OPENCLAW_API_TIMEOUT=5000